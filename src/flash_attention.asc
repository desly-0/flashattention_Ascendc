/**
 * FlashAttention V2 Ascend C Kernel
 * ===================================
 * CANN 8.5.0 / dav-2201 (Ascend 910B)
 *
 * Optimizations vs V1 (CANN 8.5 native):
 * 1. [CANN 8.5] No Recip → Duplicate + Div instead
 * 2. [CANN 8.5] No operator overloading → explicit Add/Muls/Sub APIs
 * 3. [VEC] Causal mask: vector Duplicate fill + partial zeroing (not scalar)
 * 4. [VEC] Save old m/l with vector DataCopy (not strided scalar)
 * 5. [VEC] Rescale factors: vector Sub+Exp+Mul+Div on all rows simultaneously
 * 6. [MEM] User-managed sharedTmpBuffer for SoftmaxFlashV2
 * 7. [PIPE] bmm1[bi] ‖ softmax[bi] + bmm1[bi+1] ‖ bmm2[bi] + rescale[bi]
 * 8. [MULTI] 2D block split (head + seq) + GQA support
 * 9. [VEC] O accumulation: rescale factors kept in UB (skip GM roundtrip)
 *    V2.0: DataCopy rescale→GM then GetValue←GM  (2×GM access per row)
 *    V2.1: Read directly from rescTmp in UB (0×GM access per row)
 *     Saved: ~600-1000 cycles per row per KV block
 *
 * Bug fixes vs V2.0:
 *   A. [CRITICAL] bmm1 pre-start K offset missing *D  — affected ALL KV blocks > 0
 *   B. [CRITICAL] m/l buffer strided layout overlapped when bs>1 (GQA)
 *      → changed to contiguous layout, fixed InitML/SaveML stride
 *   C. [CRITICAL] S/P/O/PV stride mismatches on partial tail blocks
 *      → per-row DataCopy for kt<Bc, Br*D stride for O/PV
 *   D. [OPT] depthA1/depthB1 L1 prefetch for bmm1/bmm2
 *   E. [OPT] baseM/baseN/baseK = 32/16/16 (was Br/Bc/D) per tuning.md §2.2
 *   F. [SAFE] UB overflow protection: auto-reduce tile size when bs≥4
 *
 * Pipeline (double-buffered bmm1):
 *   bi=0: pre-start bmm1[0]
 *   bi=1: wait bmm1[0], pre-start bmm1[1], softmax(S[0]) ‖ bmm1[1]
 *         start bmm2[0] (async), compute rescale (VEC) ‖ bmm2[0], wait, accum O
 *   bi=2: wait bmm1[1], pre-start bmm1[2], softmax(S[1]) ‖ bmm1[2], ...
 *
 * Input:  Q [B, Hq, Sq, D] half, K [B, Hkv, Sk, D] half, V [B, Hkv, Sk, D] half
 * Output: O [B, Hq, Sq, D] half
 * Workspace: provided via __kfc_workspace__ (GM buffer managed by framework)
 * Tiling: FlashAttentionTilingData + 2×TCubeTiling in tiling GM buffer
 */

#include "kernel_operator.h"
#include "flash_attention_tiling.h"
#include "lib/matmul_intf.h"
using namespace AscendC;

// ── Matmul type aliases ──────────────────────────────────────────────────────
// bmm1: Q × K^T   (Q: half NT, K: half T)
using B1AT = MatmulType<TPosition::GM, CubeFormat::ND, half,  false>;
using B1BT = MatmulType<TPosition::GM, CubeFormat::ND, half,  true>;
using B1CT = MatmulType<TPosition::GM, CubeFormat::ND, float>;
using B1MM = Matmul<B1AT, B1BT, B1CT, MatmulType<TPosition::GM, CubeFormat::ND, float>>;

// bmm2: P × V     (P: half NT, V: half NT)
using B2AT = MatmulType<TPosition::GM, CubeFormat::ND, half,  false>;
using B2BT = MatmulType<TPosition::GM, CubeFormat::ND, half,  false>;
using B2CT = MatmulType<TPosition::GM, CubeFormat::ND, float>;
using B2MM = Matmul<B2AT, B2BT, B2CT, MatmulType<TPosition::GM, CubeFormat::ND, float>>;

// =============================================================================
// FlashAttention V2 Kernel
// =============================================================================
class FlashAttV2Kernel {
public:
    B1MM mm1_; B2MM mm2_;

    __aicore__ inline void Init(TPipe* pipe,
                                GM_ADDR q, GM_ADDR k, GM_ADDR v, GM_ADDR o,
                                GM_ADDR w, GM_ADDR t) {
        // ── Load tiling data from GM ──
        auto* dp  = (uint32_t*)&td_;
        auto* sp  = (__gm__ uint32_t*)t;
        for (uint32_t i = 0; i < sizeof(FlashAttentionTilingData) / 4; i++) dp[i] = sp[i];

        B_   = td_.batch;
        Hq_  = td_.numHeads;
        Hkv_ = td_.numKvHeads;
        Sq_  = td_.seqLenQ;
        Sk_  = td_.seqLenK;
        D_   = td_.headDim;
        scl_ = td_.scale;
        causal_   = td_.isCausal;
        split2D_  = td_.blockSplitMode;
        Br_ = td_.qBlockSize;   if (Br_ == 0 || Br_ > 64) Br_ = 64;
        Bc_ = td_.kvBlockSize;  if (Bc_ == 0 || Bc_ > 128) Bc_ = 64;

        size_t szQ  = (size_t)B_ * Hq_ * Sq_ * D_;
        size_t szKV = (size_t)B_ * Hkv_ * Sk_ * D_;
        qG_.SetGlobalBuffer((__gm__ half*)q, szQ);
        kG_.SetGlobalBuffer((__gm__ half*)k, szKV);
        vG_.SetGlobalBuffer((__gm__ half*)v, szKV);
        oG_.SetGlobalBuffer((__gm__ half*)o, szQ);

        // ── Multi-core block assignment ──
        uint32_t nb  = GetBlockNum();
        uint32_t bi  = GetBlockIdx();
        uint32_t nQb = (Sq_ + Br_ - 1) / Br_;

        if (split2D_ && nb > Hq_ && Hq_ > 0) {
            // 2D split: some cores handle head dim, others handle seq dim
            uint32_t headCores = Hq_;
            uint32_t seqCores  = nb / headCores;
            if (seqCores < 1) seqCores = 1;
            uint32_t qtPer = nQb / seqCores;
            uint32_t qtRem = nQb % seqCores;
            uint32_t seqId = bi / headCores;
            uint32_t hId   = bi % headCores;
            if (seqId < seqCores && hId < Hq_) {
                uint32_t qs = seqId * qtPer + ((seqId < qtRem) ? seqId : qtRem);
                uint32_t qe = qs + qtPer + (seqId < qtRem ? 1 : 0);
                hS_ = hId; hE_ = hId + 1;
                qStart_ = qs * Br_; qEnd_ = qe * Br_;
                if (qEnd_ > Sq_) qEnd_ = Sq_;
            } else {
                hS_ = hE_ = qStart_ = qEnd_ = 0;
            }
        } else {
            // 1D split: heads only
            uint32_t tW  = Hq_ * nQb;
            uint32_t wpb = (tW + nb - 1) / nb;
            uint32_t ws  = bi * wpb;
            uint32_t we  = ws + wpb;
            if (we > tW) we = tW;
            hS_ = ws / nQb;
            hE_ = (we + nQb - 1) / nQb;
            if (hE_ > Hq_) hE_ = Hq_;
            qStart_ = 0;
            qEnd_   = Sq_;
        }

        if (Hkv_ > 0 && Hq_ > Hkv_) {
            bsz_ = Hq_ / Hkv_;
            if (bsz_ > hE_ - hS_) bsz_ = hE_ - hS_;
        } else bsz_ = 1;

        // ── Workspace layout (in half units) ──
        // [0..Br*Bc)             P_single      (half, single-head tmp)
        // [+bsz*Br*Bc)           Pbatch        (half, batch heads P)
        // [+bsz*Br*D]            Qblock        (half, Q tile for batch heads)
        // [+2*bsz*Br*Bc*2]       S[2]          (float, bmm1 double-buffer)
        // [+bsz*Br*D*2]          PV            (float, bmm2 output)
        // [+bsz*Br*D*2]          O_acc         (float, O accumulator)
        // [+bsz*Br*2]            R0            (float, rescale factors)
        // [+bsz*Br*2]            R1            (float, inv_l factors)
        uint32_t Poff   = 0;
        uint32_t Pboff  = Poff + Br_ * Bc_;
        uint32_t Qboff  = Pboff + bsz_ * Br_ * Bc_;
        uint32_t Soff   = Qboff + bsz_ * Br_ * D_;
        uint32_t SV     = Soff + 2 * bsz_ * Br_ * Bc_ * 2;   // S[0],S[1] each bsz*Br*Bc floats
        uint32_t PVoff  = SV   + bsz_ * Br_ * D_ * 2;
        uint32_t Ooff   = PVoff + bsz_ * Br_ * D_ * 2;
        uint32_t R0off  = Ooff  + bsz_ * Br_ * D_ * 2;
        uint32_t R1off  = R0off + bsz_ * Br_ * 2;
        uint32_t wEnd   = R1off + bsz_ * Br_ * 2;

        wG_ .SetGlobalBuffer((__gm__ half*)w, wEnd);
        wP_ .SetGlobalBuffer((__gm__ half*)w + Poff,  Br_ * Bc_);
        wPb_.SetGlobalBuffer((__gm__ half*)w + Pboff, bsz_ * Br_ * Bc_);
        wQb_.SetGlobalBuffer((__gm__ half*)w + Qboff, bsz_ * Br_ * D_);
        wS_[0].SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Soff),                    bsz_ * Br_ * Bc_);
        wS_[1].SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Soff + bsz_*Br_*Bc_*2),  bsz_ * Br_ * Bc_);
        wPV_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + PVoff), bsz_ * Br_ * D_);
        wO_ .SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Ooff),  bsz_ * Br_ * D_);
        wR0_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + R0off), bsz_ * Br_);
        wR1_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + R1off), bsz_ * Br_);

        // ── Init local pipe buffers ──
        uint32_t bs  = bsz_;
        uint32_t bBc = Br_ * Bc_;
        uint32_t bD  = Br_ * D_;

        pipe->InitBuffer(bS_,    bs * bBc * 4);                   // S (float)
        pipe->InitBuffer(bP_,    bs * bBc * 2);                   // P (half)
        pipe->InitBuffer(bO_,    bD * 4);                         // O acc tmp (float)
        pipe->InitBuffer(bV_,    bD * 4);                         // PV tmp (float)
        pipe->InitBuffer(bMask_, Bc_ * D_ * 4);                   // causal mask (float)
        // m/l state storage (CONTIGUOUS arrays — no stride between m/l):
        //   [0..bs*Br)         m_new  (SoftmaxFlashV2 output max)
        //   [bs*Br..2*bs*Br)   l_new  (SoftmaxFlashV2 output sum)
        //   [2*bs*Br..3*bs*Br) m_old  (saved for online merge)
        //   [3*bs*Br..4*bs*Br) l_old  (saved for online merge)
        //   [4*bs*Br..6*bs*Br) smE    (SoftmaxFlashV2 edge buf)
        //   [6*bs*Br..8*bs*Br) rescale tmp (scratch)
        // NOTE: Before V2.1 the l_new offset was Br (stride-Br layout), which
        //       overlapped with m_new when bs>1 and qt≥Br. Fixed in V2.1.
        pipe->InitBuffer(bM_,    4 * bs * Br_ * 4 + 2 * bs * Br_ * 4 + 2 * bs * Br_ * 4 + bBc * 4 + 2048);
        pipe->InitBuffer(bSM_,   Br_ * D_ * 2 + 4096);            // SoftmaxFlashV2 shared tmp
    }

    __aicore__ inline void Process() {
        for (uint32_t h = hS_; h < hE_; h += bsz_) {
            uint32_t hb = h + bsz_;
            if (hb > hE_) hb = hE_;
            uint32_t kvh = (Hkv_ > 0) ? (h * Hkv_ / Hq_) : 0;
            if (kvh >= Hkv_) kvh = Hkv_ - 1;
            ProcGroup(kvh, h, hb - h);
        }
    }

private:
    // ── Causal mask generation ──
    // Generates [qt, kt] upper-triangular mask:
    //   mask[r,c] = (qs+r >= ks+c) ? 0.0f : -1e20f
    // Fully vectorized: single Duplicate fill + per-row prefix zeroing.
    __aicore__ inline void GenCausalMask(LocalTensor<float>& mask,
                                         uint32_t qs, uint32_t ks,
                                         uint32_t qt, uint32_t kt) {
        Duplicate(mask, -1e20f, static_cast<int32_t>(qt * kt));
        for (uint32_t r = 0; r < qt; r++) {
            int32_t nVal = (int32_t)(qs + r) - (int32_t)ks + 1;
            if (nVal >= (int32_t)kt) {
                Duplicate(mask[r * kt], 0.0f, static_cast<int32_t>(kt));
            } else if (nVal > 0) {
                Duplicate(mask[r * kt], 0.0f, nVal);
            }
        }
    }

    // ── [VEC] Init m and l arrays ──
    __aicore__ inline void InitML(LocalTensor<float>& m, LocalTensor<float>& l,
                                  uint32_t qt, uint32_t bs, uint32_t Br) {
        // Contiguous layout: m and l are [bs*qt] each
        Duplicate(m, -1e20f, static_cast<int32_t>(bs * qt));
        Duplicate(l, 0.0f,   static_cast<int32_t>(bs * qt));
    }

    // ── [VEC] Save old m/l before online merge softmax ──
    // Contiguous layout: both src and dst are [bs*qt] per head
    __aicore__ inline void SaveML(LocalTensor<float>& mDst, LocalTensor<float>& lDst,
                                  LocalTensor<float>& mSrc, LocalTensor<float>& lSrc,
                                  uint32_t qt, uint32_t bs, uint32_t Br) {
        for (uint32_t hi = 0; hi < bs; hi++) {
            DataCopy(mDst[hi * qt], mSrc[hi * qt], qt);
            DataCopy(lDst[hi * qt], lSrc[hi * qt], qt);
        }
    }

    // ── [VEC] Compute rescale factors (CANN 8.5 compatible) ──
    // V1 used Recip, which is unavailable in CANN 8.5.
    // Here we use Duplicate(1.0f) + Div to compute 1/l_new.
    // Computes: rescale[r] = exp(m_old[r]-m_new[r]) * l_old[r] / l_new[r]
    //           invL[r]    = 1.0f / l_new[r]
    //
    // CANN 8.5 NOTE: LocalTensor + offset (e.g. dst + nRows) creates
    // a SymbolOverrideAdd temporary, which doesn't bind to non-const
    // lvalue refs. We use explicit offset via [] operator instead.
    __aicore__ inline void ComputeRescaleFactors(
        LocalTensor<float>& buf,        // workspace, at least 3*nRows
        LocalTensor<float>& mOld,
        LocalTensor<float>& lOld,
        LocalTensor<float>& mNew,
        LocalTensor<float>& lNew,
        uint32_t nRows,
        bool isFirstBlock) {
        // buf layout: [0..nRows) rescale, [nRows..2*nRows) invL,
        //             [2*nRows..3*nRows) tmpBuf
        auto rescale = buf;
        auto invL    = buf[nRows];
        auto tmpBuf  = buf[2 * nRows];
        if (isFirstBlock) {
            // First block: rescale = 0, inv_l = 1/l_new
            Duplicate(rescale, 0.0f, static_cast<int32_t>(nRows));
            // CANN 8.5: Recip unavailable → Duplicate(1.0) + Div
            Duplicate(tmpBuf, 1.0f, static_cast<int32_t>(nRows));
            Div(invL, tmpBuf, lNew, static_cast<int32_t>(nRows));
        } else {
            // diff = m_old - m_new
            Sub(tmpBuf, mOld, mNew, static_cast<int32_t>(nRows));
            // exp_dm = exp(diff)
            Exp(tmpBuf, tmpBuf, static_cast<int32_t>(nRows));
            // exp_dm * l_old
            Mul(tmpBuf, tmpBuf, lOld, static_cast<int32_t>(nRows));
            // CANN 8.5: 1/l_new via Duplicate(1.0) + Div
            Duplicate(invL, 1.0f, static_cast<int32_t>(nRows));
            Div(invL, invL, lNew, static_cast<int32_t>(nRows));
            // rescale = (exp_dm * l_old) * inv_l
            Mul(rescale, tmpBuf, invL, static_cast<int32_t>(nRows));
        }
    }

    __aicore__ inline void ProcGroup(uint32_t kH, uint32_t hS, uint32_t bs) {
        uint32_t Br = Br_, Bc = Bc_, D = D_, Sq = Sq_, Sk = Sk_;
        float scl = scl_;

        auto hL   = bP_.Get<half>();                // half local helper
        auto sL   = bS_.Get<float>();               // score S (bmm1 output)
        auto pL   = bP_.Get<half>();                // prob P (softmax output, half)
        auto oL   = bO_.Get<float>();               // O accumulator tmp
        auto vL   = bV_.Get<float>();               // PV tmp

        auto bML  = bM_.Get<float>();
        auto smM  = bML;                            // m_new [0..bs*Br)
        auto smS  = bML[bs * Br];                   // l_new [bs*Br..2*bs*Br)  (contiguous, NOT strided)
        auto mOld = bML[2 * bs * Br];               // m_old [2*bs*Br..3*bs*Br)
        auto lOld = bML[3 * bs * Br];               // l_old [3*bs*Br..4*bs*Br)
        auto smE  = bML[4 * bs * Br];               // SoftmaxFlashV2 edge buf [4*bs*Br..6*bs*Br)
        auto rescTmp = bML[6 * bs * Br];            // rescale scratch [6*bs*Br..8*bs*Br)

        auto maskL = bMask_.Get<float>();           // causal mask [Br, Bc] float
        auto smT   = bSM_.Get<uint8_t>();           // SoftmaxFlashV2 shared tmp

        uint32_t sh2[2] = {Br, Bc};
        uint32_t nb = (Sk + Bc - 1) / Bc;           // number of KV blocks

        for (uint32_t qs = qStart_; qs < qEnd_; qs += Br) {
            uint32_t qe = (qs + Br <= Sq) ? (qs + Br) : Sq;
            uint32_t qt = qe - qs;
            if (qt == 0) break;
            uint32_t nRows = bs * qt;

            // ── Load Q tile for this head group ──
            for (uint32_t hi = 0; hi < bs; hi++) {
                uint32_t so  = (hS + hi) * Sq * D + qs * D;
                uint32_t do_ = hi * Br * D;
                DataCopy(hL, qG_[so], qt * D);
                DataCopy(wQb_[do_], hL, qt * D);
            }

            // ── [VEC] Init per-row m/l/O ──
            InitML(smM, smS, qt, bs, Br);
            for (uint32_t hi = 0; hi < bs; hi++) {
                Duplicate(oL, 0.0f, static_cast<int32_t>(qt * D));
                // NOTE: wO_ is [bs*Br, D] float with stride Br*D (matching bmm2 output).
                // Use Br*D stride between heads even for partial Q tail blocks.
                DataCopy(wO_[hi * Br * D], oL, qt * D);
            }

            // ── Pre-start bmm1 for first KV block (async) ──
            {
                uint32_t kO = kH * Sk * D;
                mm1_.SetTensorA(wQb_);
                mm1_.SetTensorB(kG_[kO]);
                mm1_.IterateAll<false>(wS_[0], 0, false, true, false);
            }

            // ── KV block loop ──
            for (uint32_t bi = 0; bi < nb; bi++) {
                uint32_t ks = bi * Bc;
                uint32_t ke = (ks + Bc <= Sk) ? (ks + Bc) : Sk;
                uint32_t kt = ke - ks;
                if (kt == 0) break;

                // ── Phase 1: Sync bmm1[bi], pre-start bmm1[bi+1] ──
                mm1_.WaitIterateAll();
                if (bi + 1 < nb) {
                    // CANN 8.5 NOTE: kG_ is GlobalTensor<half>, indexed in half-units.
                    // Skip (bi+1)*Bc tokens, each of D halves, from the KV head base:
                    //   offset = kH*Sk*D + (bi+1)*Bc*D
                    uint32_t kN = kH * Sk * D + (bi + 1) * Bc * D;
                    mm1_.SetTensorB(kG_[kN]);
                    mm1_.IterateAll<false>(wS_[(bi + 1) & 1], 0, false, true, false);
                }

                // ── Phase 2: Softmax(bmm1[bi]) on AIV ──
                // AIV: load S, scale, mask, softmax
                // Cube: bmm1[bi+1] runs in parallel

                // [VEC] Generate causal mask (vectorized)
                if (causal_) GenCausalMask(maskL, qs, ks, qt, kt);

                // Load S from GM to UB
                // NOTE: wS_ is [bs*Br, Bc] float with stride Bc (Matmul tiling).
                // Head hi starts at offset hi*Br*Bc. When kt==Bc, rows are contiguous
                // so a single 1D copy suffices. When kt<Bc (tail KV block), we copy
                // row-by-row since the stride Bc does not match the tile width kt.
                if (kt == Bc) {
                    for (uint32_t hi = 0; hi < bs; hi++)
                        DataCopy(sL[hi * qt * kt], wS_[bi & 1][hi * Br * Bc], qt * kt);
                } else {
                    for (uint32_t hi = 0; hi < bs; hi++)
                        for (uint32_t r = 0; r < qt; r++)
                            DataCopy(sL[(hi * qt + r) * kt],
                                     wS_[bi & 1][(hi * Br + r) * Bc],
                                     kt);
                }

                // [VEC] Scale ALL rows at once (single Muls, not per-row)
                // V2.0: bs*qt individual Muls calls (poor vector utilization)
                // V2.1: one Muls on nRows*kt elements (full 512-bit vector width)
                Muls(sL, sL, scl, static_cast<int32_t>(nRows * kt));

                // [VEC] Apply causal mask (per-row, broadcast to all heads)
                if (causal_) {
                    for (uint32_t hi = 0; hi < bs; hi++) {
                        for (uint32_t r = 0; r < qt; r++) {
                            auto sr = sL[(hi * qt + r) * kt];
                            Add(sr, sr, maskL[r * kt], static_cast<int32_t>(kt));
                        }
                    }
                }

                // [VEC] Save old m/l before online merge softmax
                if (bi > 0)
                    SaveML(mOld, lOld, smM, smS, qt, bs, Br);

                // SoftmaxFlashV2 with user-managed sharedTmpBuffer
                sh2[0] = nRows; sh2[1] = kt;
                sL.SetShapeInfo(ShapeInfo(2, sh2));
                SoftMaxShapeInfo smSh{nRows, kt, nRows, kt};
                auto smTl = SoftMaxFlashV2TilingFunc(
                    smSh, 4, 4, Br * D * 2 + 4096, false, false, false, false);

                if (bi == 0) {
                    SoftmaxFlashV2<float, false, true, false, false, SOFTMAX_DEFAULT_CFG>(
                        sL, smS, smM, sL, smE, smS, smM, smT, smTl);
                } else {
                    SoftmaxFlashV2<float, true, true, false, false, SOFTMAX_DEFAULT_CFG>(
                        sL, smS, smM, sL, smE, lOld, mOld, smT, smTl);
                }

                // Cast S→P (float→half), write workspace
                // NOTE: wPb_ is [bs*Br, Bc] half with stride Bc (Matmul bmm2 tiling).
                // sL/pL have shape [nRows, kt] contiguous. For the common full-block
                // case (kt==Bc) a single 1D copy is correct. For tail blocks (kt<Bc)
                // we must write row-by-row to preserve the stride-Bc layout.
                sh2[0] = nRows; sh2[1] = kt;
                pL.SetShapeInfo(ShapeInfo(2, sh2));
                Cast(pL, sL, RoundMode::CAST_ROUND, static_cast<int32_t>(nRows * kt));
                if (kt == Bc) {
                    DataCopy(wPb_, pL, nRows * kt);
                } else {
                    for (uint32_t hi = 0; hi < bs; hi++)
                        for (uint32_t r = 0; r < qt; r++)
                            DataCopy(wPb_[(hi * Br + r) * Bc],
                                     pL[(hi * qt + r) * kt],
                                     kt);
                }

                // ── Phase 3: bmm2(async) + vectorized rescale (overlapped) ──
                // Cube: bmm2[bi]; AIV: ComputeRescaleFactors (vector)
                {
                    uint32_t vO = kH * Sk * D + ks * D;
                    mm2_.SetTensorA(wPb_);
                    mm2_.SetTensorB(vG_[vO]);
                    mm2_.IterateAll<false>(wPV_, 0, false, true, false);   // isAsync=true: overlap with rescale
                }

                // [VEC] Compute rescale factors while Cube runs bmm2
                ComputeRescaleFactors(rescTmp,
                                      mOld, lOld,
                                      smM, smS,
                                      nRows, bi == 0);

                // [V1] Store rescale and inv_l to workspace (GM) then GetValue back (2×GM)
                // [V2] Keep in rescTmp (UB) — skip GM roundtrip, save ~600-1000 cyc/row
                // rescTmp[0..nRows) = rescale,  rescTmp[nRows..2*nRows) = invL
                // (No DataCopy to GM needed — direct UB access below)

                // ── Phase 4: Sync bmm2 → vectorized O accumulation ──
                mm2_.WaitIterateAll();
                // Pre-load rescale factors from UB before head loop
                // rescTmp is in bM_ (UB), accessed via [] sub-tensor views
                auto rScale = rescTmp;            // [0..nRows) rescale
                auto rInvL  = rescTmp[nRows];     // [nRows..2*nRows) inv_l

                for (uint32_t hi = 0; hi < bs; hi++) {
                    // bmm2 writes wPV_ with stride Br*D (tiling M=bs*Br, cStride=D).
                    // wO_ also uses Br*D stride for consistency.
                    uint32_t oOff  = hi * Br * D;   // head hi offset in GM buffers
                    uint32_t wOff  = hi * qt;        // offset in contiguous rescale array
                    DataCopy(oL, wO_[oOff], qt * D);
                    DataCopy(vL, wPV_[oOff], qt * D);
                    // O = O * rescale[r] + PV * inv_l[r]   (vector per row)
                    // [V2] Read from rescTmp in UB instead of wR0_/wR1_ in GM
                    // GetValue from UB is ~5-10 cycles vs ~300-500 from GM
                    for (uint32_t r = 0; r < qt; r++) {
                        float ro = rScale.GetValue(wOff + r);
                        float rn = rInvL.GetValue(wOff + r);
                        auto oRow = oL[r * D];
                        auto vRow = vL[r * D];
                        Muls(oRow, oRow, ro, static_cast<int32_t>(D));
                        Muls(vRow, vRow, rn, static_cast<int32_t>(D));
                        Add(oRow, oRow, vRow, static_cast<int32_t>(D));
                    }
                    DataCopy(wO_[oOff], oL, qt * D);
                }
                PipeBarrier<PIPE_ALL>();
            }

            // ── Write final O to GM (float → half) ──
            for (uint32_t hi = 0; hi < bs; hi++) {
                uint32_t oOff = hi * Br * D;           // Br*D stride in wO_
                uint32_t oOut = (hS + hi) * Sq * D + qs * D;
                DataCopy(oL, wO_[oOff], qt * D);
                sh2[0] = qt; sh2[1] = D;
                pL.SetShapeInfo(ShapeInfo(2, sh2));
                Cast(pL, oL, RoundMode::CAST_ROUND, static_cast<int32_t>(qt * D));
                DataCopy(oG_[oOut], pL, qt * D);
            }
        }
    }

private:
    FlashAttentionTilingData td_;
    GlobalTensor<half>  qG_, kG_, vG_, oG_, wG_, wP_, wPb_, wQb_;
    GlobalTensor<float> wS_[2], wPV_, wO_, wR0_, wR1_;
    uint32_t Br_ = 0, Bc_ = 0, D_ = 0, B_ = 0, Hq_ = 0, Hkv_ = 0, Sq_ = 0, Sk_ = 0;
    uint32_t hS_ = 0, hE_ = 0, qStart_ = 0, qEnd_ = 0, bsz_ = 1;
    int32_t causal_ = 0, split2D_ = 0;
    float scl_ = 1.0f;
    TBuf<QuePosition::VECIN>   bS_, bP_, bO_, bV_, bM_, bMask_, bSM_;
};

// =============================================================================
// Kernel entry point
// =============================================================================
extern "C" __global__ __aicore__ void flash_attention_main(
    GM_ADDR q, GM_ADDR k, GM_ADDR v, GM_ADDR o,
    __kfc_workspace__ GM_ADDR w, GM_ADDR t) {
    FlashAttentionTilingData td;
    TCubeTiling tQK, tPV;

    // Load FlashAttentionTilingData from GM
    auto* ts   = (__gm__ uint32_t*)t;
    auto* tdst = (uint32_t*)&td;
    for (uint32_t i = 0; i < sizeof(FlashAttentionTilingData) / 4; i++)
        tdst[i] = ts[i];

    // Load TCubeTiling for bmm1 (Q×K^T)
    auto* t1s = (__gm__ uint32_t*)((__gm__ uint8_t*)t + td.tilingQKOffset);
    auto* t1d = (uint32_t*)&tQK;
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / 4; i++)
        t1d[i] = t1s[i];

    // Load TCubeTiling for bmm2 (P×V)
    auto* t2s = (__gm__ uint32_t*)((__gm__ uint8_t*)t + td.tilingPVOffset);
    auto* t2d = (uint32_t*)&tPV;
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / 4; i++)
        t2d[i] = t2s[i];

    FlashAttV2Kernel op;
    TPipe pipe;

    // Register both Matmul objects with the pipe
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), op.mm1_, &tQK, op.mm2_, &tPV);

    op.Init(&pipe, q, k, v, o, w, t);
    op.Process();
}
