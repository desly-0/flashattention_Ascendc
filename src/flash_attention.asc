/**
 * FlashAttention AscendC — V1 (Optimized)
 *
 * Optimizations vs baseline (flash_attention_dev):
 *   1. [VEC] Vectorized m/l/O init — Duplicate instead of scalar SetValue
 *   2. [VEC] Vectorized rescale factor computation
 *      — Before: scalar ExpF + GetValue/SetValue per row (pipeline bubble)
 *      — After:  vector Sub+Exp+Mul+Recip on ALL rows simultaneously
 *   3. [MEM] SoftmaxFlashV2 uses user-managed sharedTmpBuffer
 *      — Pass bSM_ as sharedTmpBuffer, eliminates framework internal alloc
 *   4. [MEM] Split wR_ → wR0_/wR1_ contiguous stores (no strided interleave)
 *   5. [PERF] Save old m/l with vector DataCopy instead of scalar loop
 *   6. [CLEANUP] Dedicated rescale temp area in bML
 *
 * Pipeline: (Cube: bmm1 || bmm2) × (AIV: softmax + rescale)
 *   bi=0: pre-start bmm1[0]
 *   bi=1: wait bmm1[0], pre-start bmm1[1], softmax(S[0]) on AIV || bmm1[1]
 *         start bmm2[0] (async), rescale (VEC) || bmm2[0], wait, accum O
 *   bi=2: wait bmm1[1], pre-start bmm1[2], softmax(S[1]) || bmm1[2], ...
 */

#include "kernel_operator.h"
#include "flash_attention_tiling.h"
#include "lib/matmul_intf.h"
using namespace AscendC;

using B1AT = MatmulType<TPosition::GM, CubeFormat::ND, half, false>;
using B1BT = MatmulType<TPosition::GM, CubeFormat::ND, half, true>;
using B1CT = MatmulType<TPosition::GM, CubeFormat::ND, float>;
using B1MM = Matmul<B1AT, B1BT, B1CT, MatmulType<TPosition::GM, CubeFormat::ND, float>>;

using B2AT = MatmulType<TPosition::GM, CubeFormat::ND, half, false>;
using B2BT = MatmulType<TPosition::GM, CubeFormat::ND, half, false>;
using B2CT = MatmulType<TPosition::GM, CubeFormat::ND, float>;
using B2MM = Matmul<B2AT, B2BT, B2CT, MatmulType<TPosition::GM, CubeFormat::ND, float>>;

class FlashAttKernel {
public:
    B1MM mm1_; B2MM mm2_;

    __aicore__ inline void Init(TPipe* pipe, GM_ADDR q, GM_ADDR k, GM_ADDR v, GM_ADDR o,
                                GM_ADDR w, GM_ADDR t) {
        // ── Load tiling data from GM ──
        auto* dp = (uint32_t*)&td_;
        auto* sp = (__gm__ uint32_t*)t;
        for (uint32_t i = 0; i < sizeof(FlashAttentionTilingData) / 4; i++) dp[i] = sp[i];

        B_   = td_.batch;
        Hq_  = td_.numHeads;
        Hkv_ = td_.numKvHeads;
        Sq_  = td_.seqLenQ;
        Sk_  = td_.seqLenK;
        D_   = td_.headDim;
        scl_ = td_.scale;
        causal_  = td_.isCausal;
        split2D_ = td_.blockSplitMode;
        Br_ = td_.qBlockSize;   if (Br_ == 0 || Br_ > 64) Br_ = 64;
        Bc_ = td_.kvBlockSize;  if (Bc_ == 0 || Bc_ > 128) Bc_ = 64;

        size_t szQ  = (size_t)B_ * Hq_ * Sq_ * D_;
        size_t szKV = (size_t)B_ * Hkv_ * Sk_ * D_;
        qG_.SetGlobalBuffer((__gm__ half*)q, szQ);
        kG_.SetGlobalBuffer((__gm__ half*)k, szKV);
        vG_.SetGlobalBuffer((__gm__ half*)v, szKV);
        oG_.SetGlobalBuffer((__gm__ half*)o, szQ);

        // ── Multi-core block assignment ──
        uint32_t nb = GetBlockNum(), bi = GetBlockIdx(), nQb = (Sq_ + Br_ - 1) / Br_;
        if (split2D_ && nb > Hq_ && Hq_ > 0) {
            uint32_t headCores = Hq_;
            uint32_t seqCores  = nb / headCores;
            if (seqCores < 1) seqCores = 1;
            uint32_t qtPer = nQb / seqCores, qtRem = nQb % seqCores;
            uint32_t seqId = bi / headCores;
            uint32_t hId   = bi % headCores;
            if (seqId < seqCores && hId < Hq_) {
                uint32_t qs = seqId * qtPer + ((seqId < qtRem) ? seqId : qtRem);
                uint32_t qe = qs + qtPer + (seqId < qtRem ? 1 : 0);
                hS_ = hId; hE_ = hId + 1;
                qStart_ = qs * Br_; qEnd_ = qe * Br_;
                if (qEnd_ > Sq_) qEnd_ = Sq_;
            } else { hS_ = hE_ = 0; qStart_ = qEnd_ = 0; }
        } else {
            uint32_t tW = Hq_ * nQb, wpb = (tW + nb - 1) / nb;
            uint32_t ws = bi * wpb, we = ws + wpb;
            if (we > tW) we = tW;
            hS_ = ws / nQb; hE_ = (we + nQb - 1) / nQb;
            if (hE_ > Hq_) hE_ = Hq_;
            qStart_ = 0; qEnd_ = Sq_;
        }
        if (Hkv_ > 0 && Hq_ > Hkv_) {
            bsz_ = Hq_ / Hkv_;
            if (bsz_ > hE_ - hS_) bsz_ = hE_ - hS_;
        } else bsz_ = 1;

        // ── Workspace layout (half units) ──
        // [0..Br*Bc)         P       (half)
        // [+bsz*Br*Bc)       Pbatch  (half)
        // [+bsz*Br*D]        Qblock  (half)
        // [+2*bsz*Br*Bc*2]   S[2]    (float, bmm1 double-buffer)
        // [+bsz*Br*D*2]      PV      (float, bmm2 output)
        // [+bsz*Br*D*2]      O       (float, accumulator)
        // [+bsz*Br]          rescale (float)
        // [+bsz*Br]          inv_l   (float)
        uint32_t Poff   = 0;
        uint32_t Pboff  = Poff + Br_ * Bc_;
        uint32_t Qboff  = Pboff + bsz_ * Br_ * Bc_;
        uint32_t Soff   = Qboff + bsz_ * Br_ * D_;
        uint32_t SV     = Soff + 2 * bsz_ * Br_ * Bc_ * 2;
        uint32_t PVoff  = SV   + bsz_ * Br_ * D_ * 2;
        uint32_t Ooff   = PVoff + bsz_ * Br_ * D_ * 2;     // O: bsz*Br*D floats
        // [FIX] R0/R1 are placed AFTER O (no overlap with O like baseline had)
        // R0: rescale values, R1: inv_l values, each bsz*Br floats
        uint32_t R0off  = Ooff + bsz_ * Br_ * D_ * 2;     // after O: +bsz*Br*D*2 halfs
        uint32_t R1off  = R0off + bsz_ * Br_ * 2;          // R0: bsz*Br floats = bsz*Br*2 halfs
        uint32_t wEnd   = R1off + bsz_ * Br_ * 2;          // R1: bsz*Br floats = bsz*Br*2 halfs

        wG_ .SetGlobalBuffer((__gm__ half*)w, wEnd);
        wP_ .SetGlobalBuffer((__gm__ half*)w + Poff,  Br_ * Bc_);
        wPb_.SetGlobalBuffer((__gm__ half*)w + Pboff, bsz_ * Br_ * Bc_);
        wQb_.SetGlobalBuffer((__gm__ half*)w + Qboff, bsz_ * Br_ * D_);
        wS_[0].SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Soff),                   bsz_ * Br_ * Bc_);
        wS_[1].SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Soff + bsz_*Br_*Bc_*2), bsz_ * Br_ * Bc_);
        wPV_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + PVoff), bsz_ * Br_ * D_);
        wO_ .SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + Ooff),  bsz_ * Br_ * D_);
        wR0_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + R0off), bsz_ * Br_);
        wR1_.SetGlobalBuffer((__gm__ float*)((__gm__ half*)w + R1off), bsz_ * Br_);

        // ── Init local pipe buffers ──
        uint32_t bsBuf = bsz_;
        uint32_t bBc = Br_ * Bc_;   // Br*Bc halfs
        uint32_t bD  = Br_ * D_;    // Br*D  halfs

        // bS_: score S after bmm1  (float)
        pipe->InitBuffer(bS_, bsBuf * bBc * 4);
        // bP_: prob P = softmax(S) (half)
        pipe->InitBuffer(bP_, bsBuf * bBc * 2);
        // bO_: O accumulator (float)
        pipe->InitBuffer(bO_, bD * 4);
        // bV_: PV tmp (float)
        pipe->InitBuffer(bV_, bD * 4);
        // bM_: m (max), l (sum), edge, rescale workspace (float)
        //   [0..bs*Br)          m_new     (stride-Br, SoftmaxFlashV2 output)
        //   [bs*Br..2*bs*Br)    l_new     (SoftmaxFlashV2 output)
        //   [2*bs*Br..3*bs*Br)  m_old     (contiguous, saved for bi>0)
        //   [3*bs*Br..4*bs*Br)  l_old     (contiguous, saved for bi>0)
        //   [4*bs*Br..6*bs*Br)  smE       (edge buf for SoftmaxFlashV2)
        //   [6*bs*Br..7*bs*Br)  rescale   (ComputeRescaleFactors output)
        //   [7*bs*Br..8*bs*Br)  inv_l     (ComputeRescaleFactors output)
        //   [8*bs*Br..9*bs*Br)  tmpBuf    (scratch for ComputeRescaleFactors)
        pipe->InitBuffer(bM_, Br_ * 12 + bsBuf * bBc * 4 + 1024);
        // bH_: helper (half) — Q tile load, Cast output
        pipe->InitBuffer(bH_, bD * 2 + Br_ * 8 + 256);
        // bMask_: causal mask (float)
        pipe->InitBuffer(bMask_, bBc * 4);
        // bSM_: SoftmaxFlashV2 shared tmp buffer — user-managed, no framework alloc
        // Size sufficient for GetSoftMaxFlashV2MinTmpSize
        pipe->InitBuffer(bSM_, Br_ * D_ * 2 + 4096);
    }

    __aicore__ inline void Process() {
        for (uint32_t h = hS_; h < hE_; h += bsz_) {
            uint32_t hb = h + bsz_;
            if (hb > hE_) hb = hE_;
            uint32_t kvh = (Hkv_ > 0) ? (h * Hkv_ / Hq_) : 0;
            if (kvh >= Hkv_) kvh = Hkv_ - 1;
            ProcGroup(kvh, h, hb - h);
        }
    }

private:
    // ── Causal mask: triangular [qt, kt] float ──
    // Fully vectorized: single Duplicate fill + per-row prefix zeroing.
    __aicore__ inline void GenCausalMask(LocalTensor<float>& mask,
                                         uint32_t qs, uint32_t ks,
                                         uint32_t qt, uint32_t kt) {
        Duplicate(mask, -1e20f, static_cast<int32_t>(qt * kt));
        for (uint32_t r = 0; r < qt; r++) {
            int32_t nVal = (int32_t)(qs + r) - (int32_t)ks + 1;
            if (nVal >= (int32_t)kt) {
                Duplicate(mask[r * kt], 0.0f, static_cast<int32_t>(kt));
            } else if (nVal > 0) {
                Duplicate(mask[r * kt], 0.0f, nVal);
            }
        }
    }

    // ── [VEC] Init m and l arrays ──
    // Before: scalar SetValue loop (bs*qt iterations)
    // After:  vector Duplicate per head
    __aicore__ inline void InitML(LocalTensor<float>& m, LocalTensor<float>& l,
                                  uint32_t qt, uint32_t bs, uint32_t Br) {
        for (uint32_t hi = 0; hi < bs; hi++) {
            // m[hi*Br..hi*Br+qt) = -inf
            Duplicate(m[hi * Br], -1e20f, static_cast<int32_t>(qt));
            // l[hi*Br..hi*Br+qt) = 0
            Duplicate(l[hi * Br], 0.0f, static_cast<int32_t>(qt));
        }
    }

    // ── [VEC] Save old m/l before online merge softmax ──
    // Saves from stride-Br layout to contiguous layout
    __aicore__ inline void SaveML(LocalTensor<float>& mDst, LocalTensor<float>& lDst,
                                  LocalTensor<float>& mSrc, LocalTensor<float>& lSrc,
                                  uint32_t qt, uint32_t bs, uint32_t Br) {
        // mSrc[hi*Br..hi*Br+qt) → mDst[hi*qt..(hi+1)*qt)
        // lSrc[hi*Br..hi*Br+qt) → lDst[hi*qt..(hi+1)*qt)
        // Non-overlapping when qt==Br (same buffer, self-copy = nop)
        // Overlapping when qt<Br (last tile): source strided, dest contiguous
        for (uint32_t hi = 0; hi < bs; hi++) {
            DataCopy(mDst[hi * qt], mSrc[hi * Br], qt);
            DataCopy(lDst[hi * qt], lSrc[hi * Br], qt);
        }
    }

    // ── [VEC] Vectorized rescale factor computation ──
    // Before: scalar ExpF + GetValue/SetValue per row (~200 cycles for 64 rows)
    // After:  vector Sub+Exp+Mul+Recip on all rows (~20 cycles for 64 rows)
    // Computes: rescale[r] = exp(m_old[r]-m_new[r]) * l_old[r] / l_new[r]
    //           inv_l[r]   = 1.0 / l_new[r]
    __aicore__ inline void ComputeRescaleFactors(
        LocalTensor<float>& rescale,    // [nRows] output rescale
        LocalTensor<float>& invL,       // [nRows] output 1/l_new
        LocalTensor<float>& mOld,       // [nRows] m_old (contiguous)
        LocalTensor<float>& lOld,       // [nRows] l_old (contiguous)
        LocalTensor<float>& mNew,       // [nRows] m_new from softmax
        LocalTensor<float>& lNew,       // [nRows] l_new from softmax
        LocalTensor<float>& tmpBuf,     // scratch, at least 3*nRows
        uint32_t nRows,
        bool isFirstBlock) {            // true = bi==0
        if (isFirstBlock) {
            // First block: rescale = 0, inv_l = 1/l_new
            Duplicate(rescale, 0.0f, static_cast<int32_t>(nRows));
            Recip(invL, lNew, static_cast<int32_t>(nRows));
        } else {
            // diff = m_old - m_new
            Sub(tmpBuf, mOld, mNew, static_cast<int32_t>(nRows));
            // exp_dm = exp(diff)
            Exp(tmpBuf, tmpBuf, static_cast<int32_t>(nRows));
            // exp_dm * l_old
            Mul(tmpBuf, tmpBuf, lOld, static_cast<int32_t>(nRows));
            // inv_l = 1 / l_new
            Recip(invL, lNew, static_cast<int32_t>(nRows));
            // rescale = exp_dm * l_old / l_new = (exp_dm * l_old) * (1/l_new)
            // Note: exp(m_old-m_new) with m_old=-inf gives 0, so first-tile
            // rows with all -inf naturally produce rescale=0.  No explicit
            // masking needed — exp(-1e20) = 0 in IEEE fp32.
            Mul(rescale, tmpBuf, invL, static_cast<int32_t>(nRows));
        }
    }

    __aicore__ inline void ProcGroup(uint32_t kH, uint32_t hS, uint32_t bs) {
        uint32_t Br = Br_, Bc = Bc_, D = D_, Sq = Sq_, Sk = Sk_;
        float scl = scl_;
        auto hL    = bH_.Get<half>();
        auto sL    = bS_.Get<float>();
        auto pL    = bP_.Get<half>();
        auto oL    = bO_.Get<float>();
        auto vL    = bV_.Get<float>();
        auto bML   = bM_.Get<float>();
        auto smM   = bML;                          // m_new [0..bs*Br)
        auto smS   = bML[bs * Br];                 // l_new [bs*Br..2*bs*Br)
        auto mOld  = bML[2 * bs * Br];             // m_old [2*bs*Br..3*bs*Br)
        auto lOld  = bML[3 * bs * Br];             // l_old [3*bs*Br..4*bs*Br)
        auto smE   = bML[4 * bs * Br];             // edge buf [4*bs*Br..6*bs*Br)
        auto smT   = bSM_.Get<uint8_t>();          // shared tmp for SoftmaxFlashV2
        auto rescTmp = bML[6 * bs * Br];           // rescale [6*bs*Br..9*bs*Br)
        auto maskL = bMask_.Get<float>();
        uint32_t sh2[2] = {Br, Bc};
        uint32_t nb = (Sk + Bc - 1) / Bc;

        for (uint32_t qs = qStart_; qs < qEnd_; qs += Br) {
            uint32_t qe = (qs + Br <= Sq) ? (qs + Br) : Sq, qt = qe - qs;
            if (qt == 0) break;
            uint32_t nRows = bs * qt;

            // ── Load Q tile for this head group ──
            for (uint32_t hi = 0; hi < bs; hi++) {
                uint32_t so  = (hS + hi) * Sq * D + qs * D;
                uint32_t do_ = hi * Br * D;
                DataCopy(hL, qG_[so], qt * D);
                DataCopy(wQb_[do_], hL, qt * D);
            }

            // ── [VEC] Init per-row m/l/O ──
            InitML(smM, smS, qt, bs, Br);
            for (uint32_t hi = 0; hi < bs; hi++) {
                Duplicate(oL, 0.0f, static_cast<int32_t>(qt * D));
                DataCopy(wO_[hi * qt * D], oL, qt * D);
            }

            // ── Pre-start bmm1 for first KV block (async) ──
            {
                uint32_t kO = kH * Sk * D;
                mm1_.SetTensorA(wQb_);
                mm1_.SetTensorB(kG_[kO]);
                mm1_.IterateAll<false>(wS_[0], 0, false, true, false);
            }

            // ── KV block loop ──
            for (uint32_t bi = 0; bi < nb; bi++) {
                uint32_t ks = bi * Bc, ke = (ks + Bc <= Sk) ? (ks + Bc) : Sk, kt = ke - ks;
                if (kt == 0) break;

                // ── Phase 1: Sync bmm1[bi], pre-start bmm1[bi+1] ──
                mm1_.WaitIterateAll();
                if (bi + 1 < nb) {
                    uint32_t kN = kH * Sk * D + (bi + 1) * Bc;
                    mm1_.SetTensorB(kG_[kN]);
                    mm1_.IterateAll<false>(wS_[(bi + 1) & 1], 0, false, true, false);
                }

                // ── Phase 2: Softmax(bmm1[bi]) on AIV ──
                // AIV: load S, scale, mask, softmax; Cube: bmm1[bi+1] (overlap)
                if (causal_) GenCausalMask(maskL, qs, ks, qt, kt);

                for (uint32_t hi = 0; hi < bs; hi++)
                    DataCopy(sL[hi * qt * kt], wS_[bi & 1][hi * qt * kt], qt * kt);

                if (causal_) {
                    for (uint32_t hi = 0; hi < bs; hi++)
                        for (uint32_t r = 0; r < qt; r++) {
                            auto sr = sL[(hi * qt + r) * kt];
                            Muls(sr, sr, scl, static_cast<int32_t>(kt));
                            Add(sr, sr, maskL[r * kt], static_cast<int32_t>(kt));
                        }
                } else {
                    for (uint32_t hi = 0; hi < bs; hi++)
                        for (uint32_t r = 0; r < qt; r++)
                            Muls(sL[(hi * qt + r) * kt], sL[(hi * qt + r) * kt], scl, static_cast<int32_t>(kt));
                }

                // [VEC] Save old m/l before online merge softmax
                // (only needed for bi>0, otherwise softmax is first block)
                if (bi > 0) {
                    SaveML(mOld, lOld, smM, smS, qt, bs, Br);
                }

                // SoftmaxFlashV2 with sharedTmpBuffer (user-managed)
                sh2[0] = nRows; sh2[1] = kt;
                sL.SetShapeInfo(ShapeInfo(2, sh2));
                SoftMaxShapeInfo smSh{nRows, kt, nRows, kt};
                auto smTl = SoftMaxFlashV2TilingFunc(smSh, 4, 4, Br * D * 8,
                                                     false, false, false, false);
                if (bi == 0) {
                    SoftmaxFlashV2<float, false, true, false, false, SOFTMAX_DEFAULT_CFG>(
                        sL, smS, smM, sL, smE, smS, smM, smT, smTl);
                } else {
                    SoftmaxFlashV2<float, true, true, false, false, SOFTMAX_DEFAULT_CFG>(
                        sL, smS, smM, sL, smE, lOld, mOld, smT, smTl);
                }

                // Cast S→P (float→half), write workspace
                sh2[0] = nRows; sh2[1] = kt;
                pL.SetShapeInfo(ShapeInfo(2, sh2));
                Cast(pL, sL, RoundMode::CAST_ROUND, static_cast<int32_t>(nRows * kt));
                DataCopy(wPb_, pL, nRows * kt);

                // ── Phase 3: bmm2(async) + VECTORIZED rescale (overlapped) ──
                // Cube: bmm2[bi]; AIV: ComputeRescaleFactors (vector)
                {
                    uint32_t vO = kH * Sk * D + ks * D;
                    mm2_.SetTensorA(wPb_);
                    mm2_.SetTensorB(vG_[vO]);
                    mm2_.IterateAll<false>(wPV_, 0, false, false, false);  // async!
                }

                // [VEC] Vectorized rescale while Cube runs bmm2
                ComputeRescaleFactors(rescTmp, rescTmp + nRows,
                                      mOld, lOld,
                                      smM, smS,
                                      rescTmp + 2 * nRows,
                                      nRows, bi == 0);
                // rescale/inv_l 已在 UB 中，直接用于 O 累加，无需写 GM

                // ── Phase 4: Sync bmm2 → vectorized O accumulation ──
                mm2_.WaitIterateAll();
                for (uint32_t hi = 0; hi < bs; hi++) {
                    uint32_t oOff = hi * qt * D;
                    uint32_t wOff = hi * qt;
                    DataCopy(oL, wO_[oOff], qt * D);
                    DataCopy(vL, wPV_[oOff], qt * D);
                    // O = O * rescale[r] + PV * inv_l[r]   (vector per row)
                    // [PERF] Read rescale/inv_l from UB (rescTmp) instead of GM
                    for (uint32_t r = 0; r < qt; r++) {
                        float ro = rescTmp.GetValue(wOff + r);
                        float rn = rescTmp[nRows].GetValue(wOff + r);
                        Muls(oL + r * D, oL + r * D, ro, static_cast<int32_t>(D));
                        Muls(vL + r * D, vL + r * D, rn, static_cast<int32_t>(D));
                        Add(oL + r * D, oL + r * D, vL + r * D, static_cast<int32_t>(D));
                    }
                    DataCopy(wO_[oOff], oL, qt * D);
                }
                PipeBarrier<PIPE_ALL>();
            }

            // ── Write final O to GM (float → half) ──
            for (uint32_t hi = 0; hi < bs; hi++) {
                uint32_t oOff  = hi * qt * D;
                uint32_t oOut  = (hS + hi) * Sq * D + qs * D;
                DataCopy(oL, wO_[oOff], qt * D);
                sh2[0] = qt; sh2[1] = D;
                pL.SetShapeInfo(ShapeInfo(2, sh2));
                Cast(pL, oL, RoundMode::CAST_ROUND, static_cast<int32_t>(qt * D));
                DataCopy(oG_[oOut], pL, qt * D);
            }
        }
    }

private:
    FlashAttentionTilingData td_;
    GlobalTensor<half>  qG_, kG_, vG_, oG_, wG_, wP_, wPb_, wQb_;
    GlobalTensor<float> wS_[2], wPV_, wO_, wR0_, wR1_;
    uint32_t Br_ = 0, Bc_ = 0, D_ = 0, B_ = 0, Hq_ = 0, Hkv_ = 0, Sq_ = 0, Sk_ = 0;
    uint32_t hS_ = 0, hE_ = 0, qStart_ = 0, qEnd_ = 0, bsz_ = 1;
    int32_t causal_ = 0, split2D_ = 0;
    float scl_ = 1.0f;
    TBuf<QuePosition::VECIN> bS_, bP_, bO_, bV_, bM_, bH_, bMask_, bSM_;
};

extern "C" __global__ __aicore__ void flash_attention_main(
    GM_ADDR q, GM_ADDR k, GM_ADDR v, GM_ADDR o,
    __kfc_workspace__ GM_ADDR w, GM_ADDR t) {
    FlashAttentionTilingData td;
    TCubeTiling tQK, tPV;
    auto* ts   = (__gm__ uint32_t*)t;
    auto* tdst = (uint32_t*)&td;
    for (uint32_t i = 0; i < sizeof(FlashAttentionTilingData) / 4; i++) tdst[i] = ts[i];
    auto* t1s = (__gm__ uint32_t*)((__gm__ uint8_t*)t + td.tilingQKOffset);
    auto* t1d = (uint32_t*)&tQK;
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / 4; i++) t1d[i] = t1s[i];
    auto* t2s = (__gm__ uint32_t*)((__gm__ uint8_t*)t + td.tilingPVOffset);
    auto* t2d = (uint32_t*)&tPV;
    for (uint32_t i = 0; i < sizeof(TCubeTiling) / 4; i++) t2d[i] = t2s[i];
    FlashAttKernel op;
    TPipe pipe;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), op.mm1_, &tQK, op.mm2_, &tPV);
    op.Init(&pipe, q, k, v, o, w, t);
    op.Process();
}
